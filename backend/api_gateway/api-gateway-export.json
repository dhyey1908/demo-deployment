{
  "openapi": "3.0.1",
  "info": {
    "title": "Serverless Demo API",
    "version": "1.0.0",
    "description": "Swagger source of truth for the demo AWS SAM backend."
  },
  "paths": {
    "/login": {
      "post": {
        "operationId": "login",
        "x-lambda-name": "demo_auth_api",
        "responses": {
          "200": {
            "description": "Successful login response"
          }
        }
      }
    },
    "/logout": {
      "post": {
        "operationId": "logout",
        "x-lambda-name": "demo_auth_api",
        "responses": {
          "200": {
            "description": "Successful logout response"
          }
        }
      }
    },
    "/dashboard/get_summary": {
      "get": {
        "operationId": "getDashboardSummary",
        "x-lambda-name": "demo_dashboard_api",
        "responses": {
          "200": {
            "description": "Dashboard summary response"
          }
        }
      }
    },
    "/dashboard/get_today_attendance": {
      "get": {
        "operationId": "getTodayAttendance",
        "x-lambda-name": "demo_dashboard_api",
        "responses": {
          "200": {
            "description": "Today's attendance response"
          }
        }
      }
    },
    "/employee/list": {
      "get": {
        "operationId": "listEmployees",
        "x-lambda-name": "demo_employee_api",
        "x-layer-names": ["demo_common"],
        "responses": {
          "200": {
            "description": "Employee list response"
          }
        }
      }
    },
    "/employee/add": {
      "post": {
        "operationId": "addEmployee",
        "x-lambda-name": "demo_employee_api",
        "x-layer-names": ["demo_common"],
        "responses": {
          "200": {
            "description": "Employee created response"
          }
        }
      }
    },
    "/report": {
      "post": {
        "operationId": "getReport",
        "x-lambda-name": "demo_reports_api",
        "x-layer-names": ["demo_common"],
        "x-environment": {
          "REPORT_SOURCE": "internal",
          "REPORT_REGION": "us-east-1"
        },
        "responses": {
          "200": {
            "description": "Report response"
          }
        }
      }
    }
  }
}
